{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev:laravel": "php artisan serve --host=127.0.0.1 --port=8000",
        "dev:vite": "wait-on http://127.0.0.1:8000 && vite",
        "dev": "concurrently -c \"#93c5fd,#c4b5fd\" \"npm run dev:laravel\" \"npm run dev:vite\" --names=laravel,vite --kill-others"
    },
    "devDependencies": {
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.7",
        "wait-on": "^8.0.1"
    },
    "dependencies": {
        "leaflet": "^1.9.4",
        "react-leaflet": "^4.2.1"
    }
}
